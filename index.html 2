:root{ --ink:#15191c; --ink-2:#1c2226; --paper:#ece7dc; --paper-dim:#bdb6a6; --signal:#ff6a3d; --signal-dim:#c1502c; --ok:#6aab7c; --bad:#d9534f; --line:#33393d; } *{box-sizing:border-box;} html,body{margin:0;padding:0;} body{ background:var(--ink); color:var(--paper); font-family: "Helvetica Neue", Arial, sans-serif; min-height:100vh; -webkit-font-smoothing:antialiased; } .wrap{ max-width:760px; margin:0 auto; padding:18px 16px 60px; } header{ display:flex; align-items:baseline; justify-content:space-between; border-bottom:2px solid var(--signal); padding-bottom:10px; margin-bottom:18px; } .brand{ font-weight:800; font-size:1.05rem; letter-spacing:0.04em; text-transform:uppercase; } .brand span{color:var(--signal);} .meta{ font-size:0.72rem; color:var(--paper-dim); letter-spacing:0.05em; text-transform:uppercase; } .panel{ background:var(--ink-2); border:1px solid var(--line); border-radius:4px; padding:16px; margin-bottom:14px; } h2.section-label{ font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--signal); margin:0 0 10px; font-weight:700; } .chips{ display:flex; flex-wrap:wrap; gap:6px; } .chip{ border:1px solid var(--line); background:transparent; color:var(--paper); padding:7px 12px; border-radius:99px; font-size:0.8rem; cursor:pointer; transition:all .12s ease; } .chip:hover{border-color:var(--signal);} .chip.active{ background:var(--signal); border-color:var(--signal); color:#1a1a1a; font-weight:700; } .chip .pct{ opacity:0.7; font-size:0.72rem; margin-left:4px; } .free-input{ display:flex; gap:8px; margin-top:10px; } .free-input input{ flex:1; background:var(--ink); border:1px solid var(--line); color:var(--paper); padding:9px 10px; border-radius:4px; font-size:0.85rem; } .free-input input:focus{outline:none;border-color:var(--signal);} .btn{ background:var(--signal); color:#1a1a1a; border:none; padding:9px 16px; border-radius:4px; font-weight:700; font-size:0.85rem; cursor:pointer; text-transform:uppercase; letter-spacing:0.03em; } .btn:hover{background:var(--signal-dim);} .btn.secondary{ background:transparent; border:1px solid var(--line); color:var(--paper); } .btn.secondary:hover{border-color:var(--signal);} .btn.ghost{ background:transparent; border:none; color:var(--paper-dim); text-transform:none; font-weight:400; padding:4px 0; font-size:0.78rem; text-decoration:underline; } .row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;} /* question card */ .qcard{ background:var(--ink-2); border:1px solid var(--line); border-left:4px solid var(--signal); border-radius:4px; padding:20px; } .qtopic{ font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--paper-dim); margin-bottom:8px; } .qtype{ color:var(--signal); font-weight:700; } .qtext{ font-size:1.05rem; line-height:1.5; margin-bottom:16px; white-space:pre-wrap; } .situation{ background:var(--ink); border:1px solid var(--line); border-radius:4px; padding:10px 12px; font-size:0.85rem; color:var(--paper-dim); margin-bottom:14px; white-space:pre-wrap; } .options{ display:flex; flex-direction:column; gap:8px; margin-bottom:16px; } .option{ border:1px solid var(--line); border-radius:4px; padding:10px 12px; cursor:pointer; font-size:0.92rem; display:flex; gap:10px; } .option:hover{border-color:var(--signal);} .option .num{color:var(--signal-dim);font-weight:700;} .option.correct{border-color:var(--ok);background:rgba(106,171,124,0.12);} .option.wrong{border-color:var(--bad);background:rgba(217,83,79,0.12);} .option.disabled{cursor:default;} .calc-input{ display:flex; gap:8px; margin-bottom:14px; } .calc-input input{ background:var(--ink); border:1px solid var(--line); color:var(--paper); padding:10px 12px; border-radius:4px; font-size:1rem; width:160px; } .calc-input input:focus{outline:none;border-color:var(--signal);} textarea.open-answer{ width:100%; min-height:90px; background:var(--ink); border:1px solid var(--line); color:var(--paper); padding:10px 12px; border-radius:4px; font-size:0.9rem; font-family:inherit; resize:vertical; margin-bottom:10px; } textarea.open-answer:focus{outline:none;border-color:var(--signal);} .feedback{ border-radius:4px; padding:12px 14px; margin-bottom:14px; font-size:0.88rem; line-height:1.5; white-space:pre-wrap; } .feedback.ok{background:rgba(106,171,124,0.12);border:1px solid var(--ok);color:#cfe8d6;} .feedback.bad{background:rgba(217,83,79,0.12);border:1px solid var(--bad);color:#f3cfcd;} .feedback .label{ font-weight:700; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.08em; display:block; margin-bottom:4px; } .explain{ color:var(--paper-dim); font-size:0.82rem; margin-top:8px; border-top:1px solid var(--line); padding-top:8px; } .controls{ display:flex; justify-content:space-between; align-items:center; margin-top:6px; } .stats-line{ font-size:0.75rem; color:var(--paper-dim); margin-top:14px; display:flex; justify-content:space-between; } .empty{ text-align:center; color:var(--paper-dim); padding:30px 10px; font-size:0.9rem; } footer{ text-align:center; color:var(--paper-dim); font-size:0.7rem; margin-top:24px; letter-spacing:0.04em; } @media (max-width:480px){ .qtext{font-size:0.98rem;} .calc-input input{width:120px;} } 

